    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@hono/eslint-config": "^2.0.3",
    "@types/node": "^24.10.3",
    "@vitest/eslint-plugin": "^1.5.2",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.3.2",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=24.0.0"
  }
